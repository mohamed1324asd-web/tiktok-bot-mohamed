import asyncio
import aiohttp
from aiogram import Bot, Dispatcher, types
from aiogram.filters import Command
from aiogram.types import URLInputFile

# التوكن بتاعك
API_TOKEN = '8753125623:AAGMPxhlOf4KdJ3ehX_4URloTq8WMAJJrGU'

async def main():
    bot = Bot(token=API_TOKEN)
    dp = Dispatcher()

    @dp.message(Command("start"))
    async def cmd_start(message: types.Message):
        await message.reply("🚀 البوت شغال الآن على السيرفر الجديد يا محمد!")

    @dp.message()
    async def handle_video(message: types.Message):
        url = message.text
        if "http" not in url: return
        msg = await message.reply("⏳ جاري سحب الفيديو...")
        api_url = f"https://www.tikwm.com/api/?url={url}"
        try:
            async with aiohttp.ClientSession() as session_http:
                async with session_http.get(api_url) as resp:
                    data = await resp.json()
                    video_url = data.get('data', {}).get('play')
                    if video_url:
                        await message.answer_video(video=URLInputFile(f"https://www.tikwm.com{video_url}"))
                        await msg.delete()
                    else:
                        await msg.edit_text("❌ لم أجد الفيديو.")
        except Exception as e:
            await msg.edit_text(f"❌ خطأ: {e}")

    await dp.start_polling(bot)

if __name__ == '__main__':
    asyncio.run(main())
